MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
PORT=3000
JWT_SECRET=your-secret-key-here

# Netlify only — your Railway API URL (no trailing slash)
RAILWAY_API_URL=https://your-app.up.railway.app

# Browser push reminders (free)
REMINDER_CRON_ENABLED=true
APP_URL=https://afterhours-interview-prep.netlify.app

# Generate with: npm run vapid:generate
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@afterhours.app

# Email reminders (primary — works when site is closed, free tier at resend.com)
RESEND_API_KEY=
REMINDER_EMAIL_FROM=AfterHours <onboarding@resend.dev>
